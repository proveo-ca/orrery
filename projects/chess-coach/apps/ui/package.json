{
  "name": "chess-coach-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "VITE_TARGET=web vite",
    "dev:desktop": "VITE_API_URL=http://localhost:8080 vite",
    "build": "tsgo -b && vite build",
    "build:web": "tsgo -b && VITE_TARGET=web vite build",
    "build:desktop": "tsgo -b && vite build",
    "preview": "vite preview",
    "test:int": "vitest tests/",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.81",
    "chess.js": "^1.0.0-beta.8",
    "solid-js": "^1.9.10"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^24.10.1",
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-oxlint": "^2.0.1",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.1.0"
  }
}
