{
  "name": "chess-coach-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web-no-llm": "VITE_TARGET=web-no-llm vite build && wrangler dev",
    "dev:web-no-llm:vite": "VITE_TARGET=web-no-llm vite",
    "dev:web-full:vite": "VITE_TARGET=web-full vite",
    "dev:desktop": "VITE_API_URL=http://localhost:8080 vite",
    "build:web-no-llm": "tsgo -b && VITE_TARGET=web-no-llm vite build",
    "build:web-full": "node scripts/check-web-llm-model.mjs && tsgo -b && VITE_TARGET=web-full vite build",
    "build:desktop": "tsgo -b && vite build",
    "preview": "npm run build:web-no-llm && wrangler dev",
    "preview:vite": "VITE_TARGET=web-no-llm vite build && vite preview",
    "typecheck": "tsgo -b",
    "deploy": "npm run build:web-no-llm && wrangler deploy",
    "test:int": "vitest tests/",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix --fix-suggestions --fix-dangerously",
    "format": "oxfmt"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "@solidjs/router": "^0.16.1",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "lz-string": "^1.5.0",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.12",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@typescript/native-preview": "^7.0.0-dev.20260428.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "postcss-custom-media": "^12.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-oxlint": "^2.1.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  }
}
