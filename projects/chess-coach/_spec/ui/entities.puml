' CAPABILITIES
' ══════════════════════════════════════════════════════════════

package "Capabilities  [capabilitiesStore.ts]" {

  class ScreenCapabilities {
    .. UI affordances ..
    hint: boolean
    travel: boolean
    historyNav: boolean
    evalBarAlwaysVisible: boolean
    .. Engine behavior ..
    aiOpponent: boolean
    blunderDetection: boolean
    continuousAnalysis: boolean
    bestMoveArrow: "off" | "player-only" | "both"
    commentary: boolean
    .. Persistence ..
    persistGame: boolean
    .. Board interaction ..
    historyBranching: boolean
    freeColorControl: boolean
    readOnly: boolean
    flipBoard: boolean
    .. Visual ..
    opponentUsesPlayerPieceSet: boolean
  }

  note right of ScreenCapabilities
    **COACH_CAPABILITIES**
    hint=T, travel=T, aiOpponent=T,
    blunderDetection=T, continuousAnalysis=T,
    commentary=T, persistGame=T
    (flipBoard=F, readOnly=F)

    **ANALYSIS_CAPABILITIES**
    hint=T, continuousAnalysis=T, bestMoveArrow=both,
    freeColorControl=T, flipBoard=T,
    opponentUsesPlayerPieceSet=T,
    persistGame=F (scratch-pad — moves are
      volatile, must not overwrite Coach's
      saved game)
    (aiOpponent=F, readOnly=F)

    **REVIEW_CAPABILITIES**
    historyNav=T, evalBarAlwaysVisible=T, readOnly=T,
    persistGame=F
    (historyBranching=T when game loaded)

    **LAN_PLAYER_CAPABILITIES** (both players)
    aiOpponent=F, commentary=F, hint=F,
    blunderDetection=F, continuousAnalysis=F,
    persistGame=F, freeColorControl=F,
    flipBoard=F, historyBranching=F
    readOnly = !roomStore.started()
      (board locked until both press Start;
       freeColorControl=F + activePlayerColor = chosen color
       restrict input to own color on own turn)

    **LAN_OBSERVER_CAPABILITIES**
    LAN_PLAYER + readOnly=T (always)
  end note
}

