' STORES
' ══════════════════════════════════════════════════════════════

package "Stores  [src/store/]" {

  class gameStore {
    .. Selectors ..
    game(): Chess
    currentFen(): string
    currentIndex(): number
    fenHistory(): string[]
    moveHistory(): MoveSquares[]
    isThreefoldRepetition(): boolean
    isResigned(): boolean
    .. Mutations ..
    addMove({from,to,promotion?}): Move
    addMoveSan(san): Move
    setViewIndex(n)
    goBack() / goForward()
    resetGame(fen?)
    loadFen(fen)
    loadGame({pgn, startingFen})
    resignGame()
    .. Persistence ..
    key: chess_coach_game_state
    All persistent writes (addMove, goBack/Forward,
      setViewIndex, resignGame, resetGame) call the
      internal `_persist()` which is gated by
      `capabilities().persistGame`. Analysis and
      Review screens flip that flag to false so
      their scratch-pad / review mutations don't
      overwrite the Coach's saved game; loadFen /
      loadGame already use `_notify()` (no write).
  }

  class coachStore {
    .. Selectors (hover wins over base) ..
    advice(): string
    coachEmotion(): CoachEmotion
    adviceArrow(): {from,to} | null
    hoverBlunder(): boolean
    hoverBlunderFen(): string | null
    hoverBlunderSan(): string | null
    pendingTravel(): TravelPending | null
    llmProgress(): number
    llmLoadingText(): string
    isAppReady(): boolean
    lastCoachEvent(): CoachEvent | null
    .. Mutations ..
    setAdvice(text)
    setCoachEmotion(e, autoResetMs?)
    setHoverAdvice(text | null)
    setHoverBlunder(bool, fen, san)
    clearHoverOverride()
    dispatchCoachEvent(event)
    setPendingTravel(data) / clearPendingTravel()
    .. Types ..
    CoachEmotion: idle | watching | thinking
      happy | shocked | sleepy | sleeping
    CoachEvent: APP_READY | NEW_GAME | AI_MOVED
      GAME_OVER | ADVICE_RECEIVED | SLEEPY | ...
    .. Behaviours ..
    auto-sleep after 30s/40s inactivity
    window focus wakes if sleepy/sleeping
  }

  class settingsStore {
    .. Selectors ..
    colorPref(): PlayerColorPref
    activePlayerColor(): "w" | "b"
    difficulty(): Difficulty
    blunderThresholdCp(): number
    blunderLabel(): string
    playerIdentity(): PlayerIdentity
    opponentIdentity(): PlayerIdentity
    playerName(): string  (default: random funny name)
    playerPieceSet(): PieceSet
    opponentPieceSet(): PieceSet
    imLost(): boolean
    .. Mutations ..
    setColorPref(p)
    setActivePlayerColor(c)
    setDifficulty(d)
    setPlayerIdentity(id)
    setOpponentIdentity(id)
    setPlayerName(v)
    setImLost(v)
    .. Types ..
    PlayerColorPref: w | b | random
    Difficulty: intermediate | advanced | expert
    PieceSet: cburnett | selena | gord | manuel
    PlayerIdentity: Human | Cat | Dog | Rat
    .. Constants ..
    BLUNDER_THRESHOLD_CP_BY_DIFFICULTY:
      intermediate=-200, advanced=-150, expert=-80
    BLUNDER_LABEL_BY_DIFFICULTY:
      intermediate="a blunder", advanced="a mistake",
      expert="an inaccuracy"
    .. Persistence ..
    key: chess_coach_settings_state
  }

  class gameHistoryStore {
    .. Selectors ..
    gameHistory(): GameRecord[]  (max 1000, newest first)
    inProgressGame(): GameRecord | null
    getGameById(id): GameRecord | null
    .. Mutations ..
    startNewRecord(id, fen, color, diff,
      playerRace?, opponentRace?, playerName?)
    pushMove(moveRecord)
    patchMoveAt(index, patch)
    finalizeGame(result, pgn)
    importGameRecord(record): string  (from share link; re-derives id, dedupes)
    discardInProgress()
    .. Types ..
    GameRecord: {id, startedAt, endedAt, result,
      pgn, startingFen, playerColor, difficulty, moves[],
      playerRace?, opponentRace?, playerName?, opponentName?}
    MoveRecord: {san, hasPressedHint, isAI}
    GameResult: win | loss | draw | ongoing
    id = Polyglot-Zobrist hash of move sequence
    .. Persistence ..
    key: chess_coach_history_state
  }

  class travelStore {
    .. Selectors ..
    isTravelling(): boolean
    travelFen(): string
    travelIndex(): number
    travelFenHistory(): string[]
    travelMoveHistory(): MoveSquares[]
    .. Mutations ..
    startTravel(fens, moves)
    travelForward() / travelBack()
    exitTravel()
  }

  class roomStore {
    .. Selectors ..
    role(): "host" | "guest"
    seat(): "player" | "observer"
    myColor(): "w" | "b" | null      // chosen in lobby, may change
    connectionStatus(): ConnStatus
    players(): Player[]              // ≤2, each with chosen color
    observers(): Member[]            // ≤4
    started(): boolean
    bothReady(): boolean
    isMyTurn(): boolean
    gameOver(): GameOverInfo | null
    .. Mutations ..
    setRole(r) / setConnectionStatus(s)
    addMember(peerId, seat, identity)    // host only
    removeMember(peerId)
    claimColor(peerId, color)            // take an empty color seat
    swapColors()                         // exchange the two players
    setReady(peerId, v)                  // start vote
    setStarted(v) / setGameOver(info)
    reset()
    .. Types ..
    ConnStatus: idle | offering | awaitingAnswer |
      connecting | connected | disconnected
    Player: {peerId, identity:{name,pieceSet?},
      color: "w"|"b"|null, ready: boolean}
    Member: {peerId, identity}
    Room: ≤2 players + observers (cap 4, optional)
    .. Notes ..
    Host browser is authoritative; guests/observers
      mirror RoomState broadcasts. Ephemeral — not persisted.
    Colors are NOT assigned by default — each player picks
      White/Black in the lobby; selecting the opposite seat
      swaps both players. ANY color change resets both ready
      votes (colors lock only when both press Start).
    Start gate: 2 players with distinct colors && both ready;
      observers never required (room can start with zero).
  }

  class createPersistedStore <<factory>> {
    createPersistedStore(key, initialValue)
    merges localStorage + initialValue
    guarantees: no missing keys after schema change
  }

  settingsStore    ..> createPersistedStore : factory
  gameHistoryStore ..> createPersistedStore : factory
}

