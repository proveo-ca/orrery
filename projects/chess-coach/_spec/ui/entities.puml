' HOOKS
' ══════════════════════════════════════════════════════════════

package "Hooks  [src/hooks/]" {

  package "Board Hooks" {

    class useChessBoard {
      .. Returns ..
      game(): Chess (live or travel position)
      activeGame(): Chess (always live)
      lastMove(): MoveSquares | null
      animatedMove(): MoveSquares | null
      selectedSquare(): Square | null
      hoveredSquare(): Square | null
      validMoves(): string[]
      isReplaying(): boolean
      bestMoveArrow(): {from,to} | null
        (capabilities.bestMoveArrow: off | player-only | both)
      baseEvalScore(): PositionEval | null
      pendingPromotion(): PendingPromotion | null
      .. Handlers ..
      handleSquareClick(square)
      handleSquareHover(square)
      handleBoardMouseEnter/Leave()
      handleDragStart/Enter/Drop(sq, event)
      resolvePromotion(piece: q|r|b|n)
      cancelPromotion()
      .. Notes ..
      hover engine debounce: 150ms (all stop/go + eval requests)
      integrates: useMoveExecutor · useCoachBehavior · useHoverEvaluator
      base analysis (arrow) → enginePool.evaluate(onInfo,
        interactive when bestMoveArrow shown, else normal)
      hover eval → enginePool.evaluate(interactive, onInfo)
        the two run as separate pool jobs, so hovering no longer
        interrupts the base search — best-move arrow stays stable
    }

    class useHoverEvaluator {
      threshold: settingsStore.blunderThresholdCp()
      label: settingsStore.blunderLabel()
      .. Side effects ..
      detects CP drop past difficulty threshold on hovered move
      skips when hovered move == humanBestMove (forced)
      → coachStore.setHoverBlunder(fen, san)
      → coachStore.setHoverAdvice("... is {label}")
      → coachStore.setPendingTravel(data)
      clears: clearHoverOverride() on mouse-leave
    }
  }

  package "Coach Hooks" {

    class useMoveExecutor {
      .. Module-level signals ..
      [signal] lastHumanMoveInfo:
        {san, lan, wasBestMove, gameOver} | null
      [signal] lastAIMoveInfo:
        {san, captured, humanMoveSan,
         fen, move, gameOver} | null
      [signal] lastAIError: string | null
      .. Returns ..
      executeMove(from, to, promotion?)
      .. Notes ..
      validates legality · applies to gameStore
      checks: checkmate · threefold ·
        insufficient material · generic draw
      calls postMove(req) → AI response
      calls addMoveSan(san) for AI move
    }

    class useCoachBehavior {
      .. Reactive subscriptions (createEffect) ..
      on lastHumanMoveInfo:
        abortAdvice · clear board arrows
        if !capabilities().commentary:
          setTimeout 3s → thinking phrase
          (final state — no LLM will replace it)
        else: thinking phrase shown immediately
          (placeholder — streamed advice replaces)
        if wasBestMove: praise phrase
      on lastAIMoveInfo:
        cancel pending thinking timer
        always call postAdviceStream — the api
          facade no-ops it in web-no-llm
        queen capture easter egg by PlayerIdentity
        GAME_OVER handling
      on lastAIError: setAdvice(error message)
      .. Returns ..
      abortAdvice()
      .. Notes ..
      owns: AbortController · setTimeout ref
      QUEEN_CAPTURE_PHRASES[PlayerIdentity]
    }
  }

  package "Multiplayer Hooks" {

    class useMultiplayerGame {
      .. Input ..
      transport: PeerTransport
      .. Reactive subscriptions (createEffect) ..
      on lastHumanMoveInfo (own move):
        host  → addMoveSan locally + broadcast(MoveApplied)
        guest → transport.send(Move{san})
      .. Inbound message handlers ..
      Hello        → (host) add as player / observer (≤4) / ROOM_FULL
      ClaimColor   → (host) seat color if free; reset ready votes
      SwapColor    → (host) exchange the two players' colors;
                       reset ready votes
      Move         → (host) authoritative addMoveSan + rebroadcast
      MoveApplied  → (guest/obs) reconcile via addMoveSan / loadFen
      StartRequest → (host) record ready; 2 distinct colors
                       && both → started
      RoomState    → (guest/obs) mirror players · colors ·
                       started · gameOver
      Resign       → (host) end game + broadcast
      .. Side effects ..
      setActivePlayerColor(myColor)   // re-applied on color change:
        flips orientation + input gate when a player swaps colors
      roomStore mutations
      .. Notes ..
      Pure human-vs-human: aiOpponent=F so useMoveExecutor
        never calls postMove — this hook relays instead
        (mirrors useCoachBehavior's signal-reaction pattern).
      No CoachService / harness / LLM involvement.
    }
  }

  package "Game Control Hooks" {

    class useGameControls {
      .. Module-level signal ..
      [signal] pendingHintUci: string | null
      .. Returns ..
      atStart(): boolean
      atLatest(): boolean
      isReplaying(): boolean
      isResigned(): boolean
      pendingHint(): boolean
      handleBack()
      handleForward()
      handleBackToLive()
      handleHint()
      handleResign()
      .. Notes ..
      integrates useHint()
      manages: travel vs normal navigation
      hint UI:
        capabilities().commentary
          → "Try moving X. " + streamed
            postExplainStream
          → "Try moving X." (terminal, no LLM)
    }

    class useHint {
      .. Returns ..
      requestHint(fen, depth?): Promise<string>
      stopHint()
      pendingHint(): boolean
      .. Notes ..
      enginePool.evaluate(interactive); never rejects ("" on fail)
      supersede = AbortController (pool drains the stale bestmove)
    }

    class useGlobalShortcuts <<side-effect>> {
      Space      → activateTravel (blunder only)
      Escape     → exitTravel | backToLive
      ArrowLeft  → back | travelBack
      ArrowRight → forward | travelForward
    }
  }

  package "Analysis & Review Hooks" {

    class useGameAnalysis {
      .. Input ..
      game: () => GameRecord | null
      .. Returns ..
      analysis(): GameAnalysis
      .. Module fns ..
      analyzeGameToCache(game, {signal, onState})
      deleteAnalysisCache(id) · migrateAnalysisCache(from, to)
      ANALYSIS_DEPTH = 20
      .. Types ..
      GameAnalysis: {cpDeltas[], wasBestMoves[],
        bestMoveUcis[], loading: boolean}
      .. Notes ..
      enginePool.evaluate(background) per ply (best + played)
      caches in localStorage by game id (CACHE_VERSION)
      partial progress writes every 2 plies; resumes from cache
      seedFromCache reuses the cache by ply INDEX (not exact
        length) → a shorter live-pre-analysis cache warms Review;
        only the un-cached tail is re-analyzed
      hook drives analyzeGameToCache via AbortController
    }

    class useLivePreAnalysis <<side-effect>> {
      .. Notes ..
      on CoachScreen: analyzeGameToCache(background), keyed
        by in-progress UUID, persisted per ply to localStorage
      COALESCES — one pass at a time; a move mid-pass flags a
        re-sweep instead of aborting (never discards in-flight
        ply work, which constant preemption would otherwise lose)
      finalizeGame migrates the cache → review id (warm Review)
      interactive searches (hint/hover) preempt these jobs
    }

    class useBlunderArrow {
      .. Input ..
      annotations(): AnnotationTag[][]
      bestMoveUcis(): (string | null)[]
      .. Notes ..
      shows best-move arrow for blunder/inaccuracy
        at current ply (review mode)
      falls back to live hint if cache unavailable
    }

    class useMoveListPagination {
      .. Input ..
      rows: () => MoveRow[]
      .. Returns ..
      activePly(): number
      activePage(): number
      totalPages(): number
      visibleRows(): MoveRow[]
      goToStart() / goToEnd()
      goToPrev() / goToNext()
      .. Notes ..
      ROWS_PER_PAGE = 8
      auto-follows active ply
      manual override on user navigation
    }
  }

  package "Recording & Travel Hooks" {

    class useGameRecorder <<side-effect>> {
      .. Exports ..
      markHintPressed()
      .. Behaviour ..
      on mount: backfill existing moves
      on NEW_GAME event: startNewRecord()
      on GAME_OVER event: finalizeGame(pgn)
      per move: pushMove → gameHistoryStore
      reads: lastCoachEvent() mirror signal
    }

    class useLanGameRecorder <<side-effect>> {
      .. Behaviour ..
      LAN twin of useGameRecorder, driven by room/game
        stores instead of coach signals (engine-free board)
      on roomStore.started: startNewRecord(myColor,
        playerName, opponentName)  (players only)
      per ply (fenHistory grows): pushMove → gameHistoryStore
      on roomStore.gameOver: finalizeGame(result-from-my-POV)
      onCleanup: discardInProgress if unfinished
    }

    class useSharedGameImport <<side-effect>> {
      .. Returns ..
      importError(): string | null
      importing(): boolean
      .. Behaviour ..
      onMount + hashchange: read #g= →
        gameShare.decodeGame → importGameRecord
        → navigate(/review/:id, replace)
      invalid payload: error + clear hash
    }

    class useShareGame {
      .. Returns ..
      share(record): Promise<void>
      shareMsg(): string | null
      .. Behaviour ..
      buildShareUrl → navigator.share, else
        clipboard, else prompt; URL-length guard
    }

    class useTravelMode {
      .. Returns ..
      activateTravel(blunderFen,
        blunderSan, fenBefore?)
      loading(): boolean
      .. Notes ..
      extracts 8-ply best line via Stockfish worker
      calls travelStore.startTravel(fens, moves)
      streams parallel LLM explanation
        via postExplainStream
    }
  }

  package "UX Hooks" {

    class useHintSparkle {
      .. Returns ..
      hintSparkleClass(): string
      dismissHintSparkle()
      .. Notes ..
      shows sparkle after 10s idle delay
      dismissed state persists to localStorage
    }

    class useFlip <<side-effect>> {
      useFlip(el, trigger)
      .. Notes ..
      FLIP-animates el between two layout
        positions on each trigger() change
      measures in a post-layout rAF (robust to
        effect ordering); no-op w/o WAAPI or
        under prefers-reduced-motion
      slides the history nav from its in-bar
        dock to the top-right (timeline mode)
    }
  }
}

