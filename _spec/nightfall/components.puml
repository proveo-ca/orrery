@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
title Nightfall - Component Diagram (Three.js + TypeScript)

package "Browser Runtime" {
  [Vite + Three.js Bundle\n(index.html + JS + WASM)] as ThreeBundle
  [WebLLM / Nano Models\n(q4f16_1 or smaller)] as NanoLLM
  [IndexedDB Cache] as Cache
}

package "Three.js Core" {
  [Main Scene\n(3D house + basement)] as MainScene

  component "Player" as Player {
    [Player Class] as PlayerClass
    [PointerLockControls + Camera] as FpsCamera
    [SpotLight (Flashlight)] as Flashlight
    [HeartRate System] as HeartRate
    [Inventory] as Inventory
    [Rapier CharacterController] as Physics
  }

  component "AI Agents (Cats)" as Cats {
    [Cat Class (THREE.Group)] as CatMeshes
    [CatBrain (State Machine)] as CatBrain
    [StalkingBehavior (Primary)] as Stalking
    [FleeBehavior, MischiefBehavior] as OtherBehaviors
    [Vision (Raycaster)] as CatVision
  }

  [Interactable Objects] as Interactibles
  [Environment (Lights, Curtains, Fog)] as Environment
}

package "Nano Model Layer" as Nano {
  [Tiny LLM (Phi-2, Gemma-2B, TinyLlama)\nvia WebLLM] as NanoLLM
  note right of NanoLLM
    Each cat maintains a tiny
    rolling context + personality.
    Runs entirely in browser.
  end note
}

' Relationships
ThreeBundle --> NanoLLM : "Loads & calls nano models"
ThreeBundle --------> MainScene : "Renders & runs game"

MainScene -----> Player
MainScene -----> Cats
MainScene --> Interactibles
MainScene --> Environment

PlayerClass --> FpsCamera
PlayerClass --> Flashlight
PlayerClass --> HeartRate
PlayerClass --> Inventory
PlayerClass --> Physics

Cats --> CatMeshes
CatMeshes --> CatBrain
CatBrain --> Stalking
CatBrain --> OtherBehaviors
CatBrain --> NanoLLM : "Query for next action"
CatMeshes --> CatVision

Interactibles --> PlayerClass : "Raycast interaction\n(curtains, notes, doors)"
Environment --> HeartRate : "Affects BPM\n(sounds, darkness, cat proximity)"
Environment --> Flashlight : "Battery / Flicker"

note bottom of ThreeBundle
  • Pure browser experience (Vite build)
  • Three.js + Rapier physics
  • All AI runs locally via WebLLM
  • 20-minute real-time survival loop
  • Final reveal: curtains open → cats are just troublemakers
end note

note right of CatBrain
  Current implementation:
  - StalkingBehavior is the primary action
  - Simple state machine as safety net
  - Vision + heart rate as context
  - Ready for WebLLM integration
end note

@enduml
