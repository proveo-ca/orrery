@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle

title Chess Coach Harness: Component Architecture

package "Kotlin Harness (Anti-Framework)" {

    [Main\n(CLI + Daemon mode)] as MAIN

    package "Core Orchestration" {
        [Orchestrator\n(The Execution Loop)] as ORCH
        [State Manager\n(FEN I/O)] as STATE
        [LlmClient\n(OpenAI-compatible HTTP)] as LLM_CLIENT
    }

    package "Engine Layer" {
        [EngineBridge\n(facade)] as BRIDGE
        [StockfishEngine] as SF
        [MaiaEngine] as MAIA
        [UciDriver\n(process + queue + timeout)] as UCI
    }
}

package "External Processes" {
    [Stockfish Binary] as STOCKFISH
    [lc0 + Maia Weights] as LC0
}

package "External Services" {
    [Ollama LLM Server] as OLLAMA
}

database "File System" as FS {
    [game_state.fen]
    [openings.bin]
    [syzygy/ (3-4-5 piece)]
}

' --- Relationships ---

MAIN --> ORCH : "CLI/daemon dispatches\nmove / advice / hello"

ORCH <-> STATE : "Read/Write FEN"
STATE --> FS : "Read/Write game_state.fen"

ORCH --> BRIDGE : "Evaluation / Move / Legality"
BRIDGE --> SF : "Eval, legality, FEN derivation"
BRIDGE --> MAIA : "AI move selection\n(difficulty-based)"
SF --> UCI : "UCI commands"
MAIA --> UCI : "UCI commands"
UCI --> STOCKFISH : "UCI Protocol\n(stdin/stdout)"
UCI --> LC0 : "UCI Protocol\n(stdin/stdout)"

ORCH --> LLM_CLIENT : "Generate coaching advice"
LLM_CLIENT --> OLLAMA : "HTTP POST\n/v1/chat/completions"

note bottom of MAIA
  **Move Generation:**
  Maia (a policy network running on lc0)
  generates the AI move directly.
  Uses openings.bin for early game variety,
  and Temperature for stochastic mid-game play.
  No LLM is involved in move selection.
  Stockfish validates legality and
  derives the resulting FEN.
end note

note top of ORCH
  **Anti-Framework Design:**
  A pure Kotlin execution loop.
  No LangChain, no hidden graphs.
  Direct control over engine I/O,
  LLM prompts, and state management.
end note

note bottom of UCI
  **UciDriver:**
  Background reader thread + queue.
  Timeout-aware line reading.
  Stderr draining prevents deadlocks.
end note

@enduml
