@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam maxMessageSize 150

title Chess Coach Harness: Execution Lifecycle

participant "Ktor API" as API
participant "Harness Daemon\n(Main)" as MAIN
participant "Orchestrator" as ORCH
participant "State Manager" as STATE
participant "EngineBridge" as BRIDGE
participant "StockfishEngine" as SF
participant "Stockfish" as STOCKFISH
participant "MaiaEngine" as MAIA
participant "lc0" as LC0
participant "LlmClient" as LLM
participant "Ollama" as OLLAMA

== Move Phase ==

API -> MAIN : JSON-line:\n{ command: "move",\n  fenAfterHuman, humanMoveSan, difficulty }
activate MAIN

MAIN -> ORCH : executeTurn(humanMoveSan, difficulty)
activate ORCH

ORCH -> STATE : Read current FEN
STATE --> ORCH : FEN string

ORCH -> BRIDGE : getEvaluation(fen, depth=15)
BRIDGE -> SF : getEvaluation(fen)
SF -> STOCKFISH : UCI: position fen ...\ngo depth 15
STOCKFISH --> SF : info score cp 45\nbestmove e2e4
SF --> BRIDGE : EvalResult(bestMove, cp)
BRIDGE --> ORCH : EvalResult (+0.45)

ORCH -> BRIDGE : getMaiaMove(fen, difficulty)
BRIDGE -> MAIA : getMove(fen, difficulty)

note over MAIA, LC0
  Maia is a policy network.
  1 node search is sufficient.
  Uses openings.bin or Temperature
  for stochastic, varied play.
  No LLM involved in move generation.
end note

MAIA -> LC0 : UCI: position fen ...\ngo nodes 1
LC0 --> MAIA : bestmove e7e5
MAIA --> BRIDGE : "e7e5"
BRIDGE --> ORCH : candidateMove

ORCH -> BRIDGE : getFenAfterMove(fen, candidateMove)
BRIDGE -> SF : getFenAfterMove(fen, move)
SF -> STOCKFISH : UCI: position fen ... moves e7e5\nd
STOCKFISH --> SF : Fen: <newFen>\nCheckers: ...
SF --> BRIDGE : newFen (or null if illegal)
BRIDGE --> ORCH : newFen

ORCH -> STATE : Write new FEN
ORCH --> MAIN : TurnResult(fen, move)
deactivate ORCH

MAIN --> API : JSON-line:\n{ fen: "<newFen>", move: "e7e5" }
deactivate MAIN

note over API
  API responds to UI:
  HTTP 200 { fen, move }
  Board updates immediately.
end note

== Advice Phase (separate request) ==

API -> MAIN : JSON-line:\n{ command: "advice",\n  humanMoveSan, aiMove, fenAfterHuman }
activate MAIN

MAIN -> ORCH : generateAdvice(humanMoveSan, aiMove, fen)
activate ORCH

ORCH -> BRIDGE : getEvaluation(fen, depth=15)
BRIDGE -> SF : getEvaluation(fen)
SF -> STOCKFISH : UCI: position fen ...\ngo depth 15
STOCKFISH --> SF : score cp, bestmove
SF --> BRIDGE : EvalResult
BRIDGE --> ORCH : Eval context for prompt

ORCH -> LLM : prompt(systemPrompt, userPrompt,\ncommentaryModel)
LLM -> OLLAMA : POST /v1/chat/completions\n(OpenAI-compatible)
OLLAMA --> LLM : ChatResponse
LLM --> ORCH : Raw advice text

ORCH --> ORCH : Extract commentary\n(regex parse)
ORCH --> MAIN : advice string
deactivate ORCH

MAIN --> API : JSON-line:\n{ advice: "..." }
deactivate MAIN

note over API
  API responds to UI:
  HTTP 200 { advice }
  Coach panel updates with commentary.
end note

@enduml
