@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle

actor User

package "Distribution 1: Cloudflare (Web Mode)" {
    package "Browser Environment" {
        [SolidJS UI] as WebUI
        
        package "Web Workers" {
            [Stockfish Worker\n(Hints & Hover)] as WebSFHint
            [Orchestrator Worker\n(Game Loop)] as WebOrch
            [Stockfish Worker\n(AI Moves & Eval)] as WebSFAi
            [WebLLM Worker\n(WebGPU Inference)] as WebLLM
        }
    }
}

package "Distribution 2: Docker Compose (Server Mode)" {
    package "Browser Environment " {
        [SolidJS UI] as DockerUI
        [Stockfish Worker\n(Hints & Hover)] as DockerSFHint
    }

    package "Docker Containers" {
        [Ktor Backend API] as Ktor
        [Kotlin Harness Daemon] as Harness
        
        package "Native Binaries" {
            [Stockfish] as NativeSF
            [Maia / lc0] as NativeMaia
        }
    }
    
    [Ollama Server] as Ollama
}

' Web Mode Connections
User --> WebUI
WebUI <-> WebSFHint : Local UCI
WebUI <-> WebOrch : postMessage (Move/Advice)
WebOrch <-> WebSFAi : UCI
WebOrch <-> WebLLM : Prompt/Stream

' Docker Mode Connections
User --> DockerUI
DockerUI <-> DockerSFHint : Local UCI
DockerUI <-> Ktor : HTTP REST
Ktor <-> Harness : JSON-line stdin/stdout
Harness <-> NativeSF : UCI
Harness <-> NativeMaia : UCI
Harness <-> Ollama : HTTP POST

@enduml
