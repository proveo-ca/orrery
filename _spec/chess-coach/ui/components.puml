@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle

title Chess Coach UI: Component Architecture (SolidJS)

actor User

package "SolidJS Frontend (chess-coach-ui)" {
  package "UI Components" {
    [ChessBoard] as BOARD
    [Controls\n(New Game, Back, Forward, Hint, Credits)] as MENU
    [CoachAdvice Panel] as COACH_PANEL
    [Avatar] as AVATAR
  }

  package "Hooks (Orchestration)" {
    [useChessBoard] as USE_CHESS_BOARD
    [useMoveExecutor] as USE_MOVE_EXEC
    [useHint] as USE_HINT
    [useStockfishWorker] as USE_STOCKFISH
  }

  package "State Management (Stores)" {
    [gameState\n(FEN History, moveHistory, currentIndex)] as GAME_STATE
    [coachState\n(base + hover override\nadvice/emotion)] as COACH_STATE
    [settingsState\n(colorPref, activePlayerColor,\ndifficulty)] as SETTINGS_STATE
  }

  package "Local Engine Layer" {
    [Stockfish Web Worker\n(/public/stockfish-18-lite.js)] as STOCKFISH_WORKER
  }

  package "Network Layer" {
    [API Client\n(services/api.ts)] as API_CLIENT
  }
}

package "Backend" {
  [Ktor API\n(chess-coach-api)] as KTOR
}

' --- Relationships ---

User --> BOARD : "Hover/Click squares"
User --> MENU : "Clicks controls"

BOARD --> USE_CHESS_BOARD : "Board interaction"
USE_CHESS_BOARD --> GAME_STATE : "Read/write FEN history\nselection/hover state derives from FEN"
USE_CHESS_BOARD --> SETTINGS_STATE : "Read active color"
USE_CHESS_BOARD --> COACH_STATE : "Set hover override\n(watching/shocked + text)"

USE_CHESS_BOARD --> USE_MOVE_EXEC : "Execute legal move"
USE_MOVE_EXEC --> API_CLIENT : "POST /move\nPOST /advice"
API_CLIENT --> KTOR : "HTTP JSON"

MENU --> GAME_STATE : "Back/Forward (index)"
MENU --> SETTINGS_STATE : "Color/difficulty"
MENU --> API_CLIENT : "POST /new\nGET /hello\nPOST /move (first move)"
MENU --> USE_HINT : "Request hint"
USE_HINT --> STOCKFISH_WORKER : "UCI: position fen, go depth 10"
USE_CHESS_BOARD --> USE_STOCKFISH : "Hover eval (go depth 6)\nBest-move baseline"
USE_STOCKFISH --> STOCKFISH_WORKER : "UCI: position fen, go depth N"

GAME_STATE --> BOARD : "Reactive FEN update"
COACH_STATE --> COACH_PANEL : "Reactive advice update"
COACH_STATE --> AVATAR : "Reactive emotion update"

note right of GAME_STATE
  **Local history:**
  FEN history is stored client-side.
  Back/Forward updates currentIndex
  without hitting the backend.
end note

note right of STOCKFISH_WORKER
  **Local evaluation:**
  Hint + hover analysis run entirely
  in the browser via a Web Worker.
end note

@enduml
