@startuml
!includeurl https://raw.githubusercontent.com/proveo-ca/identity/refs/heads/main/proveo.iuml
skinparam componentStyle rectangle

title Chess Coach UI: Component Architecture (SolidJS)

actor User

package "SolidJS Frontend (chess-coach-ui)" {
  package "UI Components" {
    [ChessBoard] as BOARD
    [Controls] as MENU
    [CoachAdvice Panel] as COACH_PANEL
  }

  package "Hooks & Stores" {
    [useMoveExecutor] as USE_MOVE_EXEC
    [useHoverEvaluator] as USE_HOVER
    [gameState / coachState] as STORES
  }

  package "Network / Service Layer (api.ts)" {
    [API Client Facade] as API_CLIENT
    [HttpCoachService] as HTTP_SVC
    [WebWorkerCoachService] as WW_SVC
  }

  package "Local Engine Layer" {
    [Stockfish Worker\n(stockfish-18-lite.js)] as SF_HINT_WORKER
  }
}

package "Distribution 1: Web Workers" {
    [Orchestrator Worker\n(orchestrator.worker.ts)] as ORCH_WORKER
    [LLM Worker\n(WebLLM)] as LLM_WORKER
    [Stockfish Worker\n(AI Moves)] as SF_AI_WORKER
}

package "Distribution 2: Backend" {
  [Ktor API] as KTOR
}

User --> BOARD : "Play move / Hover"
BOARD --> USE_MOVE_EXEC
BOARD --> USE_HOVER

USE_HOVER <--> SF_HINT_WORKER : "Local Eval (Both Modes)"

USE_MOVE_EXEC --> API_CLIENT : "postMove / postAdviceStream"

API_CLIENT --> HTTP_SVC : "If VITE_TARGET != web"
API_CLIENT --> WW_SVC : "If VITE_TARGET == web"

HTTP_SVC --> KTOR : "HTTP JSON"

WW_SVC --> ORCH_WORKER : "postMessage"
ORCH_WORKER --> LLM_WORKER : "Generate Advice (WebGPU)"
ORCH_WORKER --> SF_AI_WORKER : "UCI Eval / AI Move"

STORES --> BOARD : "Reactive FEN"
STORES --> COACH_PANEL : "Reactive Advice"

@enduml
