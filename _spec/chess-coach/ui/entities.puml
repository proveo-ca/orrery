' SERVICES
' ══════════════════════════════════════════════════════════════

package "Services  [src/services/]" {

  interface CoachService {
    postNewGame(): Promise<{fen}>
    fetchHello(): Promise<HelloResponse>
    postMove(req: MoveRequest): Promise<MoveResponse>
    postAdviceStream(req, onChunk, opts?): Promise<void>
    postExplainStream(req, onChunk, opts?): Promise<void>
    --
    api.ts gate (HAS_COMMENTARY):
      web-no-llm → postAdviceStream and
        postExplainStream resolve immediately
        without invoking the active service.
  }

  class HttpCoachService {
    .. Notes ..
    desktop mode · HTTP to Kotlin backend
    endpoints: /new · /hello · /move ·
      /advice · /explain
  }

  class WebWorkerCoachService {
    .. Notes ..
    web-full | web-no-llm mode
    spawns orchestrator.worker.ts
    routes via postMessage / onmessage
    tracks pending requests by UUID
    supports streaming via onChunk callback
  }

  class runtimeMode {
    resolveMode(): RuntimeMode
    .. Types ..
    RuntimeMode: {kind: "desktop"|"web-full"|"web-no-llm",
      apiUrl?: string}
    .. Notes ..
    reads: VITE_TARGET · VITE_API_URL
    default: "web-no-llm"
    --
    Build-time companions in vite.config.ts:
    · `__HAS_LLM__` — true iff web-full.
      Gates the WebLlmClient dynamic import.
    · `__STOCKFISH_VARIANT__` — selects
      "stockfish-18-lite-single" (web) or
      "stockfish-18-lite" (desktop). Read
      by StockfishEngine to pick the worker
      file; the unused variant is stripped
      from `dist/` post-build.
  }

  class stockfishService <<singleton>> {
    getWorker(): Worker
    send(command: string)
    addListener(fn) / removeListener(fn)
    .. Notes ..
    watchdog: detects hung worker, restarts
      with synthetic `bestmove (none)` so
      pending consumers don't hang.
    --
    Circuit breaker: > 3 restarts in 10 s
      → flips `givenUp`, terminates the
      worker, future getWorker()/send()
      become no-ops until page reload.
      Prevents a permanently-faulting wasm
      from looping into an OOM blow-up.
    --
    Stale-event guard: each onerror
      handler checks `this.worker === w`
      so drain-events from a terminated
      worker can't terminate its successor.
  }

  class browserSupport {
    checkEngineSupport(): {supported, reason, debug}
    .. Checks ..
    SharedArrayBuffer · crossOriginIsolated
    WASM shared memory (1-page probe)
    --
    Probe is intentionally tiny — we only
    confirm SAB+threads support is present
    (Maia/lc0 still needs threads). We do
    NOT pre-flight Stockfish's actual
    request size: that would consume the
    SAB budget Stockfish then needs.
  }

  class streamUtils {
    accumulateStream(stream, req, onUpdate, opts?)
    .. Notes ..
    clears placeholder on first chunk
    supports AbortSignal · optional text prefix
  }

  HttpCoachService      ..|> CoachService
  WebWorkerCoachService ..|> CoachService
}

' ══════════════════════════════════════════════════════════════
' WEB ENGINE
' ══════════════════════════════════════════════════════════════

package "WebEngine  [src/engine/]" {

  class Orchestrator {
    executeTurn(humanMoveSan, fen, diff): TurnResult
    generateAdviceStream(humanMove, aiMove, fen)
    generateExplanationStream(fenBefore, fenAfter,
      isBlunder, moveSan)
    generateUiPhrases(): UiPhrases
    .. Types ..
    TurnResult: {fen, move, advice?}
    .. Notes ..
    constructor: (LlmClient, onDebug?)
    generateUiPhrases() calls llmClient.warmup?()
      (no-op when the client doesn't implement it,
      i.e. NoopLlmClient in web-no-llm/desktop)
    builds MoveAnalysis for prompt
    sanitizes + validates LLM output
    always falls back to canned advice if
      low-quality (the api.ts gate keeps
      web-no-llm from reaching these paths)
  }

  class EngineBridge {
    getEvaluation(fen, depth=15): EvalResult
    getAiMove(fen, difficulty): string (UCI)
    getFenAfterMove(fen, uciMove): string | null
    getSanForUciMove(fen, uciMove): string | null
    .. Notes ..
    Stockfish + Maia are spawned LAZILY on
      first use (getter pattern) to avoid
      eagerly competing with main-thread
      engines for the per-origin SAB budget.
    intermediate → maia-1100 · advanced → maia-1600
    expert → maia-2200
  }

  class StockfishEngine {
    getEvaluation(fen, depth=15): EvalResult
    getMoveAtElo(fen, elo): string
    getFenAfterMove(fen, uciMove): string | null
    getSanForUciMove(fen, uciMove): string | null
    .. Types ..
    EvalResult: {bestMove, cp, isMate, mateIn, pv}
    .. Notes ..
    Worker file selected at build time by
    the `__STOCKFISH_VARIANT__` Vite define:
    · web-no-llm / web-full
        → stockfish-18-lite-single.js
          (single-threaded, no SAB)
    · desktop
        → stockfish-18-lite.js (threaded)
    --
    Web targets run two Stockfish workers
    (main-thread + orchestrator) and the
    threaded build's 128 MB / 2 GB shared
    WebAssembly.Memory request trips
    Chrome 147's per-origin SAB budget,
    cascading into a pthread-pool spawn
    loop. Single-threaded sidesteps it.
    Desktop has only the main-thread worker
    (orchestrator runs server-side), so
    threading is safe and faster.
    --
    The unused variant is stripped from
    `dist/` by the strip-unused-stockfish
    Vite plugin.
  }

  class MaiaEngine {
    init(weightsFile: string)
    getMove(fen, weightsFile): string (UCI)
    .. Notes ..
    weights: maia-1100/1600/2200.pb.gz
    WASM: lc0.wasm · go nodes 1
    auto-restart on worker crash
  }

  interface LlmClient {
    prompt(sys, user, temp?, maxTokens?): Promise<string>
    promptStream(...): AsyncGenerator<string>
    warmup?(): Promise<void>
    .. Notes ..
    `warmup` is optional. Real backends
    (WebLlmClient) implement it to pre-load
    the model into VRAM. Noop clients leave
    it undefined; Orchestrator skips the
    call entirely so web-no-llm / desktop
    builds emit no "Warming up LLM..."
    console output.
  }

  class WebLlmClient {
    .. Notes ..
    file: src/engine/WebLlmClient.ts
    @mlc-ai/web-llm · web-full mode only
    lazy chunk — orchestrator.worker.ts does
      `await import("./WebLlmClient")` only
      when __HAS_LLM__ is true; web-no-llm and
      desktop builds dead-eliminate the import
    implements warmup() — pre-loads the
      model into VRAM with a 1-token Ping
    model: chess-gemma-commentary-q0f32-MLC
    WASM: gemma-3-270m-q0f32-webgpu.wasm
  }

  class NoopLlmClient {
    .. Notes ..
    file: src/engine/LlmClient.ts (with interface)
    returns empty strings · does NOT implement
      warmup (Orchestrator skips the call)
    used as the worker's eager LlmClient when
      __HAS_LLM__ is false. In practice
      unreachable in web-no-llm (the api.ts
      gate short-circuits before postMessage).
  }

  class llmPromptFormat {
    buildAdvicePrompt(analysis: MoveAnalysis): string
    buildExplanationPrompt(...): string
    .. Types ..
    MoveAnalysis: {fenBefore, fenAfter, moveSan,
      tag, cpDelta, bestAlt, bestAltMatchesMove, ...}
  }

  class fallbackCommentary {
    fallbackAdvice(tag, ...): string
    fallbackExplanation(...): string
    .. Notes ..
    canned arrays by move tag / situation
    used when LLM output fails quality check
  }

  class moveAnnotations {
    resolveAnnotations(moves, cpDeltas,
      wasBestMoves, bestMoveUcis): AnnotationTag[][]
    pairMovesIntoRows(moves, startFen): MoveRow[]
    formatCp(cp: number): string
    .. Constants ..
    BLUNDER_THRESHOLD_CP    = -200
    INACCURACY_THRESHOLD_CP = -50
    .. Types ..
    AnnotationTag: best | blunder | inaccuracy |
      hint | forced
    MoveRow: {turn, white, whiteIndex, black, blackIndex}
  }

  WebLlmClient  ..|> LlmClient
  NoopLlmClient ..|> LlmClient

  Orchestrator  --> EngineBridge      : getEvaluation · getAiMove
  Orchestrator  --> LlmClient         : prompt / promptStream
  Orchestrator  --> llmPromptFormat   : builds prompts
  Orchestrator  --> fallbackCommentary : fallback advice
  EngineBridge  --> StockfishEngine   : evaluation
  EngineBridge  --> MaiaEngine        : AI moves
}

