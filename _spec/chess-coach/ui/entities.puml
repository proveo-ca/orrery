' ══════════════════════════════════════════════════════════════
' CAPABILITIES
' ══════════════════════════════════════════════════════════════

package "Capabilities  [capabilitiesStore.ts]" {

  class ScreenCapabilities {
    .. UI affordances ..
    hint: boolean
    travel: boolean
    historyNav: boolean
    evalBarAlwaysVisible: boolean
    .. Engine behavior ..
    aiOpponent: boolean
    blunderDetection: boolean
    continuousAnalysis: boolean
    showBestMove: boolean
    commentary: boolean
    .. Persistence ..
    persistGame: boolean
    .. Board interaction ..
    historyBranching: boolean
    freeColorControl: boolean
    readOnly: boolean
    flipBoard: boolean
    .. Visual ..
    opponentUsesPlayerPieceSet: boolean
  }

  note right of ScreenCapabilities
    **COACH_CAPABILITIES**
    hint=T, travel=T, aiOpponent=T,
    blunderDetection=T, continuousAnalysis=T,
    commentary=T, persistGame=T
    (flipBoard=F, readOnly=F)

    **ANALYSIS_CAPABILITIES**
    hint=T, continuousAnalysis=T, showBestMove=T,
    freeColorControl=T, flipBoard=T,
    opponentUsesPlayerPieceSet=T,
    persistGame=F (scratch-pad — moves are
      volatile, must not overwrite Coach's
      saved game)
    (aiOpponent=F, readOnly=F)

    **REVIEW_CAPABILITIES**
    historyNav=T, evalBarAlwaysVisible=T, readOnly=T,
    persistGame=F
    (historyBranching=T when game loaded)
  end note
}

' ══════════════════════════════════════════════════════════════
' STORES
' ══════════════════════════════════════════════════════════════

package "Stores  [src/store/]" {

  class gameStore {
    .. Selectors ..
    game(): Chess
    currentFen(): string
    currentIndex(): number
    fenHistory(): string[]
    moveHistory(): MoveSquares[]
    isThreefoldRepetition(): boolean
    isResigned(): boolean
    .. Mutations ..
    addMove({from,to,promotion?}): Move
    addMoveSan(san): Move
    setViewIndex(n)
    goBack() / goForward()
    resetGame(fen?)
    loadFen(fen)
    loadGame({pgn, startingFen})
    resignGame()
    .. Persistence ..
    key: chess_coach_game_state
    All persistent writes (addMove, goBack/Forward,
      setViewIndex, resignGame, resetGame) call the
      internal `_persist()` which is gated by
      `capabilities().persistGame`. Analysis and
      Review screens flip that flag to false so
      their scratch-pad / review mutations don't
      overwrite the Coach's saved game; loadFen /
      loadGame already use `_notify()` (no write).
  }

  class coachStore {
    .. Selectors (hover wins over base) ..
    advice(): string
    coachEmotion(): CoachEmotion
    adviceArrow(): {from,to} | null
    hoverBlunder(): boolean
    hoverBlunderFen(): string | null
    hoverBlunderSan(): string | null
    pendingTravel(): TravelPending | null
    llmProgress(): number
    llmLoadingText(): string
    isAppReady(): boolean
    lastCoachEvent(): CoachEvent | null
    .. Mutations ..
    setAdvice(text)
    setCoachEmotion(e, autoResetMs?)
    setHoverAdvice(text | null)
    setHoverBlunder(bool, fen, san)
    clearHoverOverride()
    dispatchCoachEvent(event)
    setPendingTravel(data) / clearPendingTravel()
    .. Types ..
    CoachEmotion: idle | watching | thinking
      happy | shocked | sleepy | sleeping
    CoachEvent: APP_READY | NEW_GAME | AI_MOVED
      GAME_OVER | ADVICE_RECEIVED | SLEEPY | ...
    .. Behaviours ..
    auto-sleep after 30s/40s inactivity
    window focus wakes if sleepy/sleeping
  }

  class settingsStore {
    .. Selectors ..
    colorPref(): PlayerColorPref
    activePlayerColor(): "w" | "b"
    difficulty(): Difficulty
    playerIdentity(): PlayerIdentity
    playerPieceSet(): PieceSet
    opponentPieceSet(): PieceSet
    imLost(): boolean
    .. Mutations ..
    setColorPref(p)
    setActivePlayerColor(c)
    setDifficulty(d)
    setPlayerIdentity(id)
    setImLost(v)
    .. Types ..
    PlayerColorPref: w | b | random
    Difficulty: intermediate | advanced | expert
    PieceSet: cburnett | selena | gord | manuel
    PlayerIdentity: Human | Cat | Dog | Rat
    .. Persistence ..
    key: chess_coach_settings_state
  }

  class gameHistoryStore {
    .. Selectors ..
    gameHistory(): GameRecord[]  (max 1000, newest first)
    inProgressGame(): GameRecord | null
    getGameById(id): GameRecord | null
    .. Mutations ..
    startNewRecord(id, fen, color, diff)
    pushMove(moveRecord)
    patchMoveAt(index, patch)
    finalizeGame(result, pgn)
    discardInProgress()
    .. Types ..
    GameRecord: {id, startedAt, endedAt, result,
      pgn, startingFen, playerColor, difficulty, moves[]}
    MoveRecord: {san, hasPressedHint, isAI}
    GameResult: win | loss | draw | ongoing
    id = Polyglot-Zobrist hash of move sequence
    .. Persistence ..
    key: chess_coach_history_state
  }

  class travelStore {
    .. Selectors ..
    isTravelling(): boolean
    travelFen(): string
    travelIndex(): number
    travelFenHistory(): string[]
    travelMoveHistory(): MoveSquares[]
    .. Mutations ..
    startTravel(fens, moves)
    travelForward() / travelBack()
    exitTravel()
  }

  class createPersistedStore <<factory>> {
    createPersistedStore(key, initialValue)
    merges localStorage + initialValue
    guarantees: no missing keys after schema change
  }

  settingsStore    ..> createPersistedStore : factory
  gameHistoryStore ..> createPersistedStore : factory
}

' ══════════════════════════════════════════════════════════════
' HOOKS
' ══════════════════════════════════════════════════════════════

package "Hooks  [src/hooks/]" {

  package "Board Hooks" {

    class useChessBoard {
      .. Returns ..
      game(): Chess (live or travel position)
      activeGame(): Chess (always live)
      lastMove(): MoveSquares | null
      animatedMove(): MoveSquares | null
      selectedSquare(): Square | null
      hoveredSquare(): Square | null
      validMoves(): string[]
      isReplaying(): boolean
      bestMoveArrow(): {from,to} | null
      baseEvalScore(): PositionEval | null
      pendingPromotion(): PendingPromotion | null
      .. Handlers ..
      handleSquareClick(square)
      handleSquareHover(square)
      handleBoardMouseEnter/Leave()
      handleDragStart/Enter/Drop(sq, event)
      resolvePromotion(piece: q|r|b|n)
      cancelPromotion()
      .. Notes ..
      hover eval delay: 150ms
      integrates: useMoveExecutor · useCoachBehavior
        useHoverEvaluator · useStockfishWorker
    }

    class useStockfishWorker {
      .. Returns ..
      analysis(): StockfishAnalysis
      send(command: string)
      .. Types ..
      StockfishAnalysis: {last, lastInfo, lastBestMove}
      .. Notes ..
      singleton via stockfishService
      parses UCI: info depth pv score | bestmove
    }

    class useHoverEvaluator {
      BLUNDER_THRESHOLD_CP: -200
      .. Side effects ..
      detects CP drop > 200 on hovered move
      → coachStore.setHoverBlunder(fen, san)
      → coachStore.setHoverAdvice(text)
      → coachStore.setPendingTravel(data)
      clears: clearHoverOverride() on mouse-leave
    }
  }

  package "Coach Hooks" {

    class useMoveExecutor {
      .. Module-level signals ..
      [signal] lastHumanMoveInfo:
        {san, lan, wasBestMove, gameOver} | null
      [signal] lastAIMoveInfo:
        {san, captured, humanMoveSan,
         fen, move, gameOver} | null
      [signal] lastAIError: string | null
      .. Returns ..
      executeMove(from, to, promotion?)
      .. Notes ..
      validates legality · applies to gameStore
      checks: checkmate · threefold ·
        insufficient material · generic draw
      calls postMove(req) → AI response
      calls addMoveSan(san) for AI move
    }

    class useCoachBehavior {
      .. Reactive subscriptions (createEffect) ..
      on lastHumanMoveInfo:
        abortAdvice · clear board arrows
        if !capabilities().commentary:
          setTimeout 3s → thinking phrase
          (final state — no LLM will replace it)
        else: thinking phrase shown immediately
          (placeholder — streamed advice replaces)
        if wasBestMove: praise phrase
      on lastAIMoveInfo:
        cancel pending thinking timer
        always call postAdviceStream — the api
          facade no-ops it in web-no-llm
        queen capture easter egg by PlayerIdentity
        GAME_OVER handling
      on lastAIError: setAdvice(error message)
      .. Returns ..
      abortAdvice()
      .. Notes ..
      owns: AbortController · setTimeout ref
      QUEEN_CAPTURE_PHRASES[PlayerIdentity]
    }
  }

  package "Game Control Hooks" {

    class useGameControls {
      .. Module-level signal ..
      [signal] pendingHintUci: string | null
      .. Returns ..
      atStart(): boolean
      atLatest(): boolean
      isReplaying(): boolean
      isResigned(): boolean
      pendingHint(): boolean
      handleBack()
      handleForward()
      handleBackToLive()
      handleHint()
      handleResign()
      .. Notes ..
      integrates useHint()
      manages: travel vs normal navigation
      hint UI:
        capabilities().commentary
          → "Try moving X. " + streamed
            postExplainStream
          → "Try moving X." (terminal, no LLM)
    }

    class useHint {
      .. Returns ..
      requestHint(fen, depth?): Promise<string>
      stopHint()
      pendingHint(): boolean
      .. Notes ..
      lazy-init worker on first call
      drains stale bestmove replies (drainCount)
      timeout: 12s per request
    }

    class useGlobalShortcuts <<side-effect>> {
      Space      → activateTravel (blunder only)
      Escape     → exitTravel | backToLive
      ArrowLeft  → back | travelBack
      ArrowRight → forward | travelForward
    }
  }

  package "Analysis & Review Hooks" {

    class useGameAnalysis {
      .. Input ..
      game: () => GameRecord | null
      .. Returns ..
      analysis(): GameAnalysis
      deleteAnalysisCache(id)
      .. Types ..
      GameAnalysis: {cpDeltas[], wasBestMoves[],
        bestMoveUcis[], loading: boolean}
      .. Notes ..
      spawns dedicated SF worker per game
      caches in localStorage by game id
      partial progress writes every 4 positions
      resumes from partial cache on re-entry
    }

    class useBlunderArrow {
      .. Input ..
      annotations(): AnnotationTag[][]
      bestMoveUcis(): (string | null)[]
      .. Notes ..
      shows best-move arrow for blunder/inaccuracy
        at current ply (review mode)
      falls back to live hint if cache unavailable
    }

    class useMoveListPagination {
      .. Input ..
      rows: () => MoveRow[]
      .. Returns ..
      activePly(): number
      activePage(): number
      totalPages(): number
      visibleRows(): MoveRow[]
      goToStart() / goToEnd()
      goToPrev() / goToNext()
      .. Notes ..
      ROWS_PER_PAGE = 8
      auto-follows active ply
      manual override on user navigation
    }
  }

  package "Recording & Travel Hooks" {

    class useGameRecorder <<side-effect>> {
      .. Exports ..
      markHintPressed()
      .. Behaviour ..
      on mount: backfill existing moves
      on NEW_GAME event: startNewRecord()
      on GAME_OVER event: finalizeGame(pgn)
      per move: pushMove → gameHistoryStore
      reads: lastCoachEvent() mirror signal
    }

    class useTravelMode {
      .. Returns ..
      activateTravel(blunderFen,
        blunderSan, fenBefore?)
      loading(): boolean
      .. Notes ..
      extracts 8-ply best line via Stockfish worker
      calls travelStore.startTravel(fens, moves)
      streams parallel LLM explanation
        via postExplainStream
    }
  }

  package "UX Hooks" {

    class useHintSparkle {
      .. Returns ..
      hintSparkleClass(): string
      dismissHintSparkle()
      .. Notes ..
      shows sparkle after 10s idle delay
      dismissed state persists to localStorage
    }
  }
}

