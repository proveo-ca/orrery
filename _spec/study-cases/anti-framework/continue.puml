@startuml
' Product: Continue
' URL: https://www.continue.dev/

package "Continue (IDE Extension)" {
    [Core Logic\n(Harness)] as CORE
    [IDE State\n(VSCode/JetBrains)] as GUI
    [Context Providers\n(Index/Docs/Diffs)] as CTX
    [LLM Gateway] as LLM
}

GUI <--> CORE : "Sync State"
CORE --> CTX : "Query Indexes"
CORE --> LLM : "Generate"

note right of CORE
  Separates GUI state from
  LLM logic strictly.
end note
@enduml
