@startuml
title Reflexion (Self-Correction Loop)

start
:Input Task;
:Attempt 1;

repeat
    :Execute Task;
    :Evaluate Result (Success/Fail);
    if (Success?) then (yes)
        :Final Answer;
        stop
    else (no)
        :Reflect (Self-Critique);
        note right
          "I failed because X.
           Next time I will do Y."
        end note
        :Store Reflection in Memory;
        :Retry (Attempt N+1) with Memory;
    endif
repeat while (Retries < Max?)

:Failure;
stop
@enduml
